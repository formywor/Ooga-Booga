<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8"/>
  <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
  <title>ScriptNova — Browser Launcher (HTA)</title>

  <hta:application
    applicationname="ScriptNova"
    id="app"
    border="thin"
    caption="yes"
    maximizebutton="no"
    minimizebutton="yes"
    sysmenu="yes"
    scroll="no"
    singleinstance="yes"
  />

  <style>
    html, body { height:100%; }
    body{ margin:0; font-family:"Segoe UI", Tahoma, Arial; background:#0b0f16; color:#eaf2ff; overflow:hidden; }
    .wrap{ height:100%; padding:14px; box-sizing:border-box; }
    .topbar{ border:1px solid #22314a; border-radius:14px; padding:12px 14px; background:#101828; box-shadow:0 0 18px rgba(0,229,255,0.08); }
    .brandRow{ display:table; width:100%; }
    .brandLeft,.brandRight{ display:table-cell; vertical-align:middle; }
    .brandLeft{ width:70%; }
    .brandRight{ width:30%; text-align:right; color:#9fb2d6; font-size:12px; }
    .pill{ display:inline-block; padding:6px 10px; border-radius:999px; background:#0e2a3a; border:1px solid rgba(0,229,255,0.35); color:#9fefff; font-size:12px; margin-top:6px; }
    .subpill{ display:inline-block; padding:4px 8px; border-radius:999px; background:#0c1422; border:1px solid rgba(255,255,255,0.12); color:#9fb2d6; font-size:11px; margin-top:6px; margin-right:8px; }

    .layout{ margin-top:12px; height:calc(100% - 86px); border:1px solid #22314a; border-radius:14px; background:#0f1726; overflow:hidden; }
    .sidebar{ float:left; width:240px; height:100%; border-right:1px solid #22314a; background:#0c1422; }
    .sideTitle{ padding:12px; border-bottom:1px solid #22314a; color:#9fb2d6; font-size:12px; letter-spacing:.8px; text-transform:uppercase; }

    .tab{ margin:10px; padding:10px; border:1px solid #22314a; border-radius:12px; background:#101a2b; color:#9fb2d6; font-weight:bold; }
    .sideCard{ margin:10px; padding:10px; border:1px solid #22314a; border-radius:12px; background:#0b1220; }
    .sideCard h4{ margin:0 0 8px 0; font-size:12px; letter-spacing:.8px; text-transform:uppercase; color:#9fb2d6; }
    .sideLine{ font-size:12px; color:#cfe1ff; line-height:1.35; word-break:break-word; }
    .sideLabel{ color:#9fb2d6; font-size:11px; margin-top:8px; }
    .sideBtn{
      width:100%;
      padding:10px;
      margin-top:8px;
      border-radius:10px;
      border:1px solid rgba(0,229,255,0.45);
      background:#0e2a3a;
      color:#eaf2ff;
      cursor:pointer;
      font-weight:900;
      letter-spacing:.7px;
      text-transform:uppercase;
      font-size:12px;
    }
    .sideBtn:hover{ background:#103146; }

    .main{ margin-left:240px; height:100%; padding:12px; box-sizing:border-box; overflow-y:auto; }

    .card{ border:1px solid #22314a; border-radius:14px; padding:12px; background:#0b1220; margin-bottom:10px; }
    .card h3{ margin:0 0 8px 0; font-size:12px; letter-spacing:.8px; text-transform:uppercase; color:#9fb2d6; }

    .btn{ width:100%; padding:12px; margin:8px 0; border-radius:12px; border:1px solid rgba(0,229,255,0.45); background:#0e2a3a; color:#eaf2ff; cursor:pointer; font-weight:900; letter-spacing:.7px; text-transform:uppercase; }
    .btn:hover{ background:#103146; }

    .btn2{ width:100%; padding:12px; margin:8px 0; border-radius:12px; border:1px solid rgba(124,77,255,0.45); background:#1a1840; color:#eaf2ff; cursor:pointer; font-weight:900; letter-spacing:.7px; text-transform:uppercase; }
    .btn2:hover{ background:#211f55; }

    .btn:disabled, .btn2:disabled, .sideBtn:disabled{
      opacity:.55; cursor:not-allowed;
      filter:grayscale(35%);
    }

    .field{ width:100%; padding:12px; border-radius:12px; border:1px solid #22314a; background:#070b12; color:#eaf2ff; outline:none; box-sizing:border-box; font-size:16px; }
    .note{ color:#9fb2d6; font-size:11px; line-height:1.35; }
  </style>

  <script language="JScript">
/*
SCRIPTNOVA PROPERTY NOTICE — IMPORTANT
This launcher and its logic are proprietary to ScriptNova.
Do NOT tamper with, rebrand, copy, or attempt to take over this code or its infrastructure.

For official documentation and downloads: https://scriptnovaa.com
*/

(function(){
  function A0(){alert("API offline");}
  function A1(){alert("Invalid Key");}
  function A2(m){alert("API error: "+String(m||"unknown"));}
  function A3(){alert("Too many people using the same key");}
  function A4(){alert("Launcher error");}
  function AU(){alert("Please update to the new file at https://scriptnovaa.com/download");}

  window.onerror=function(){try{A4();}catch(e){} return true;};

  var sh=new ActiveXObject("WScript.Shell");
  var fs=new ActiveXObject("Scripting.FileSystemObject");

  function tr(s){ s=String(s); return s.replace(/^\s+|\s+$/g,""); }

  // --- base64 helpers (ASCII-safe) ---
  function J(a){ return String(a||[]).split(",").join(""); }
  function B(s){
    try { return window.atob(String(s||"")); }
    catch(e){ return ""; }
  }
  function D(parts){ return B(J(parts)); }

  // --- strings (split base64) ---
  // https://api.scriptnovaa.com
  var S_API = D(["aHR0","cHM6","Ly9h","cGku","c2Ny","aXB0","bm92","YWEu","Y29t"]);
  // https://api.scriptnovaa.com/1234/version.txt
  var S_VU  = D(["aHR0","cHM6","Ly9h","cGku","c2Ny","aXB0","bm92","YWEu","Y29t","LzEy","MzQv","dmVy","c2lv","bi50","eHQ="]);

  // gomegaassist@gmail.com
  var S_EM  = D(["Z29t","ZWdh","YXNz","aXN0","QGdt","YWls","LmNv","bQ=="]);
  // https://discord.gg/gscGTMVsWE
  var S_DS  = D(["aHR0","cHM6","Ly9k","aXNj","b3Jk","Lmdn","L2dz","Y0dU","TVZz","V0U="]);

  // WMI queries
  // SELECT ProcessorId FROM Win32_Processor
  var Q1 = D(["U0VM","RUNU","IFBy","b2Nl","c3Nv","cklk","IEZS","T00g","V2lu","MzJf","UHJv","Y2Vz","c29y"]);
  // SELECT SerialNumber FROM Win32_BIOS
  var Q2 = D(["U0VM","RUNU","IFNl","cmlh","bE51","bWJl","ciBG","Uk9N","IFdp","bjMy","X0JJ","T1M="]);
  // SELECT SerialNumber FROM Win32_BaseBoard
  var Q3 = D(["U0VM","RUNU","IFNl","cmlh","bE51","bWJl","ciBG","Uk9N","IFdp","bjMy","X0Jh","c2VC","b2Fy","ZA=="]);

  // HKLM\SOFTWARE\Microsoft\Cryptography\MachineGuid
  var RG = D(["SEtF","WV9M","T0NB","TF9N","QUNI","SU5F","XFNP","RlRX","QVJF","XE1p","Y3Jv","c29m","dFxD","cnlw","dG9n","cmFw","aHlc","TWFj","aGlu","ZUd1","aWQ="]);

  // endpoints
  var E1="/api/check",E2="/api/verify",E3="/api/ui",E4="/api/launch",E5="/api/ping",E6="/api/end";

  // version gate
  var V="v13.13.14", gV=false;

  // state
  var p="none",t="",ex=0,sid="",kt=null,pt=null,cid="",hw="";

  function ST(x){ try{ document.getElementById("licenseStatus").innerText=x; }catch(e){} }
  function CB(x){
    try{
      var el=document.getElementById("clientBadge"); if(!el) return;
      x=String(x||"");
      if(x.length>=10) el.innerText="Client: "+x.substring(0,6)+"…"+x.substring(x.length-4);
      else if(x) el.innerText="Client: "+x;
      else el.innerText="Client: none";
    }catch(e){}
  }
  function UI(en){
    try{document.getElementById("btnSave").disabled=!en;}catch(e){}
    try{document.getElementById("btnVerify").disabled=!en;}catch(e){}
    try{document.getElementById("btnLaunch").disabled=!en;}catch(e){}
    try{document.getElementById("btnDiscord").disabled=!en;}catch(e){}
    try{document.getElementById("licenseKey").disabled=!en;}catch(e){}
    try{document.getElementById("startUrl").disabled=!en;}catch(e){}
  }

  function DD(){
    var d=sh.ExpandEnvironmentStrings("%APPDATA%")+"\\ScriptNova";
    if(!fs.FolderExists(d)) fs.CreateFolder(d);
    return d;
  }
  function LP(){ return DD()+"\\license.txt"; }
  function CP(){ return DD()+"\\clientid.txt"; }
  function W(pth,txt){ try{ var tf=fs.CreateTextFile(pth,true); tf.Write(String(txt||"")); tf.Close(); }catch(e){} }
  function R(pth){
    try{
      if(!fs.FileExists(pth)) return "";
      var tf=fs.OpenTextFile(pth,1,false);
      var s=tf.ReadAll(); tf.Close();
      return tr(s);
    }catch(e){ return ""; }
  }

  function okCID(s){
    s=String(s||"").replace(/^\s+|\s+$/g,"");
    if(!s) return false;
    if(s.length<16||s.length>80) return false;
    return (/^[A-Za-z0-9\-_.]+$/).test(s);
  }
  function h32(){
    var hx="0123456789abcdef",o="",i=0;
    for(i=0;i<32;i++) o+=hx.charAt(Math.floor(Math.random()*16));
    return o;
  }
  function EC(){
    var c=tr(R(CP()));
    if(okCID(c)){ cid=c; CB(cid); return; }
    var g="";
    try{
      g=String((new ActiveXObject("Scriptlet.TypeLib").Guid)||"");
      g=g.replace("{","").replace("}","").toLowerCase();
    }catch(e){ g=""; }
    if(!okCID(g)) g="sn-"+h32();
    cid=g;
    W(CP(),cid);
    CB(cid);
  }

  function WM(q,prop){
    try{
      var svc=GetObject("winmgmts:\\\\.\\root\\cimv2");
      var items=svc.ExecQuery(q);
      var en=new Enumerator(items);
      for(;!en.atEnd();en.moveNext()){
        var it=en.item(),v="";
        try{ v=it[prop]; }catch(x){ v=""; }
        v=tr(v);
        if(v) return v;
      }
    }catch(e){}
    return "";
  }
  function RR(path){ try{ return tr(sh.RegRead(path)); }catch(e){ return ""; } }
  function HW(){
    var cpu=WM(Q1,"ProcessorId");
    var bios=WM(Q2,"SerialNumber");
    var brd=WM(Q3,"SerialNumber");
    var mg=RR(RG);
    var cn="",ud="";
    try{cn=sh.ExpandEnvironmentStrings("%COMPUTERNAME%");}catch(e){cn="";}
    try{ud=sh.ExpandEnvironmentStrings("%USERDOMAIN%");}catch(e){ud="";}
    var r=tr(cpu)+"|"+tr(bios)+"|"+tr(brd)+"|"+tr(mg)+"|"+tr(cn)+"|"+tr(ud);
    r=r.replace(/\s+/g," ").replace(/\|+/g,"|").replace(/^\|+|\|+$/g,"");
    if(r.length<8 && okCID(cid)) r=r+"|CID:"+cid;
    if(r.length>220) r=r.substr(0,220);
    return r;
  }

  function HG(u){
    var http=new ActiveXObject("MSXML2.ServerXMLHTTP.6.0");
    http.setTimeouts(3000,7000,7000,12000);
    http.open("GET",u,false);
    http.send();
    return {s:http.status,t:http.responseText};
  }
  function HP(u,o){
    var http=new ActiveXObject("MSXML2.ServerXMLHTTP.6.0");
    http.setTimeouts(3000,7000,7000,12000);
    http.open("POST",u,false);
    http.setRequestHeader("Content-Type","application/json");
    http.send(JSON.stringify(o));
    return {s:http.status,t:http.responseText};
  }

  function VG(){
    gV=false; UI(false);
    var r=HG(S_VU);
    if(r.s!==200){ A0(); AU(); return false; }
    var rv=tr(r.t||"");
    if(rv!==V){ AU(); return false; }
    gV=true; UI(true);
    return true;
  }

  function SU(u){
    u=tr(u||"");
    if(!u) return false;
    if(u.indexOf("\"")!==-1 || u.indexOf("'")!==-1) return false;
    if(u.indexOf("\r")!==-1 || u.indexOf("\n")!==-1) return false;
    var l=u.toLowerCase();
    return (l.indexOf("http://")===0 || l.indexOf("https://")===0);
  }

  function SaveK(){
    if(!gV){ AU(); return; }
    var k=tr(document.getElementById("licenseKey").value);
    if(!k){ A1(); return; }
    W(LP(),k);
    ST("Key saved (not started)");
  }
  function LoadK(){ return tr(R(LP())); }

  function CHK(){
    if(!gV){ AU(); return; }
    var k=tr(document.getElementById("licenseKey").value);
    if(!k){ A1(); return; }
    var r=HG(S_API+E1+"?license="+encodeURIComponent(k));
    if(r.s!==200){ A0(); return; }
    var d=null; try{ d=JSON.parse(r.t); }catch(e){ d=null; }
    if(!d || d.ok!==true){ ST("Invalid key"); A1(); return; }
    ST("Key OK ("+d.plan+") — not started");
  }

  function SP(){
    if(!gV) return {ok:false,m:"update_required"};
    if(!okCID(cid)) EC();
    hw=HW();
    var k=tr(document.getElementById("licenseKey").value);
    if(!k) return {ok:false,m:"invalid_key"};
    if(!hw || hw.length<8) return {ok:false,m:"bad_hwid"};

    var r=HP(S_API+E2,{license:k,clientId:String(cid),hwid:String(hw)});
    if(r.s!==200){
      var j=null; try{ j=JSON.parse(r.t); }catch(e){ j=null; }
      return {ok:false,m:(j && j.error ? j.error : "offline")};
    }
    var d=null; try{ d=JSON.parse(r.t); }catch(e){ d=null; }
    if(!d || d.ok!==true){
      if(d && d.error) return {ok:false,m:d.error,a:d.active,l:d.limit};
      return {ok:false,m:"invalid"};
    }
    p=d.plan||"basic";
    t=String(d.token||"");
    ex=parseInt(d.exp,10)||0;
    sid=String(d.sessionId||"");
    if(!t || !ex || !sid) return {ok:false,m:"bad_session"};
    ST("Session ACTIVE ("+p+")");
    EK();
    HB();
    return {ok:true};
  }

  function UIc(){
    var r=HG(S_API+E3+"?token="+encodeURIComponent(t)+"&cid="+encodeURIComponent(cid));
    if(r.s!==200){
      var j=null; try{ j=JSON.parse(r.t); }catch(e){ j=null; }
      return {ok:false,e:(j && j.error ? j.error : "ui_failed")};
    }
    var d=null; try{ d=JSON.parse(r.t); }catch(e){ d=null; }
    if(!d || d.ok!==true || !d.launchNonce || !d.launchExp || !d.launchSig || !d.launchProfileId){
      return {ok:false,e:"bad_ui_json"};
    }
    return {ok:true,d:d};
  }

  function LB(u,ui){
    var r=HP(S_API+E4,{
      token:t,
      clientId:cid,
      startUrl:u,
      launchNonce:ui.launchNonce,
      launchExp:ui.launchExp,
      launchSig:ui.launchSig,
      launchProfileId:ui.launchProfileId
    });
    if(r.s!==200){
      var j=null; try{ j=JSON.parse(r.t); }catch(e){ j=null; }
      return {ok:false,e:(j && j.error ? j.error : "launch_failed")};
    }
    var d=null; try{ d=JSON.parse(r.t); }catch(e){ d=null; }
    if(!d || d.ok!==true || !d.bundle || !d.bundle.flags || !d.bundle.url){
      return {ok:false,e:"bad_launch_json"};
    }
    return {ok:true,b:d.bundle};
  }

  function P1(){ if(!t) return; try{ HP(S_API+E5,{token:t,clientId:cid}); }catch(e){} }
  function HB(){ HStop(); P1(); pt=window.setInterval(P1,60000); }
  function HStop(){ if(pt){ try{window.clearInterval(pt);}catch(e){} pt=null; } }
  function END(){ if(!t) return; HStop(); try{ HP(S_API+E6,{token:t,clientId:cid}); }catch(e){} }

  function EK(){
    if(kt){ try{window.clearTimeout(kt);}catch(e){} kt=null; }
    if(!ex) return;
    var d=(ex*1000)-(new Date().getTime()); if(d<0) d=0;
    kt=window.setTimeout(function(){
      END(); KILL();
      p="none"; t=""; ex=0; sid="";
      ST("Session EXPIRED");
    },d);
  }

  function FC(){
    var p1="C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe";
    var p2="C:\\Program Files (x86)\\Google\\Chrome\\Application\\chrome.exe";
    var p3=sh.ExpandEnvironmentStrings("%LOCALAPPDATA%")+"\\Google\\Chrome\\Application\\chrome.exe";
    if(fs.FileExists(p1)) return p1;
    if(fs.FileExists(p2)) return p2;
    if(fs.FileExists(p3)) return p3;
    return "";
  }
  function KILL(){ try{ sh.Run("taskkill /IM chrome.exe /F",0,true); }catch(e){} }

  function NF(f){
    f=tr(f||"");
    if(!f) return "";
    if(/[\r\n\t\0]/.test(f)) return "";
    if(f.indexOf("--")!==0) return "";
    if(/[&|<>^%`]/.test(f)) return "";
    return f;
  }
  function UA(f){
    f=String(f||"");
    if(f.indexOf("--user-agent=")!==0) return f;
    var v=tr(f.substring(13)).replace(/"/g,"");
    if(/\s/.test(v)) return '--user-agent="'+v+'"';
    return "--user-agent="+v;
  }
  function QI(s){
    s=String(s||"");
    if(!s) return "";
    if(s.indexOf('"')!==-1) return s;
    if(/\s/.test(s)) return '"'+s+'"';
    return s;
  }
  function BA(flags,url){
    var i=0,parts=[];
    for(i=0;i<flags.length;i++){
      var x=NF(flags[i]);
      if(!x) continue;
      x=UA(x);
      parts.push(x);
    }
    parts.push(QI(url));
    return parts.join(" ");
  }

  function WMIrun(exe,args){
    try{
      var svc=GetObject("winmgmts:\\\\.\\root\\cimv2");
      var pr=svc.Get("Win32_Process");
      var inp=pr.Methods_("Create").InParameters.SpawnInstance_();
      inp.CommandLine='"'+exe+'" '+args;
      var outp=pr.ExecMethod_("Create",inp);
      var rv=9999;
      try{ rv=outp.ReturnValue; }catch(e){ rv=9999; }
      return (rv===0);
    }catch(e){ return false; }
  }
  function RUN(exe,args){
    var cmd='"'+exe+'" '+args;
    try{ sh.Run(cmd,0,false); return true; }catch(e){ return false; }
  }

  function LCH(){
    if(!gV){ AU(); return; }
    var u=tr(document.getElementById("startUrl").value);
    if(!u) u="https://example.com";
    if(!SU(u)){ A2("unsafe_url"); return; }

    var c=FC();
    if(!c){ A4(); return; }

    KILL();

    var s=SP();
    if(!s.ok){
      if(s.m==="update_required"){ AU(); }
      else if(s.m==="offline"){ A0(); }
      else if(s.m==="too_many_sessions"){ A3(); }
      else if(s.m==="invalid_key"||s.m==="invalid"){ A1(); }
      else { A2(s.m); }
      HStop(); p="none"; t=""; ex=0; sid="";
      ST("Key saved (not started)");
      return;
    }

    var ui=UIc();
    if(!ui.ok){
      if(ui.e==="offline") A0(); else A2(ui.e);
      END(); p="none"; t=""; ex=0; sid="";
      ST("Key saved (not started)");
      return;
    }

    var lb=LB(u,ui.d);
    if(!lb.ok){
      if(lb.e==="offline") A0(); else A2(lb.e);
      END(); p="none"; t=""; ex=0; sid="";
      ST("Key saved (not started)");
      return;
    }

    var as=BA(lb.b.flags,String(lb.b.url||u));
    if(WMIrun(c,as)) return;
    if(RUN(c,as)) return;

    END(); p="none"; t=""; ex=0; sid="";
    ST("Key saved (not started)");
    A4();
  }

  function DIS(){
    if(!gV){ AU(); return; }
    try{ document.getElementById("startUrl").value=S_DS; }catch(e){}
  }

  function INIT(){
    EC(); hw=HW();

    try{ document.getElementById("supportEmail").innerText=S_EM; }catch(e){}
    try{ document.getElementById("supportDiscord").innerText=S_DS; }catch(e){}

    var saved=LoadK();
    if(saved) document.getElementById("licenseKey").value=saved;

    VG();

    if(gV) ST(saved ? "Key saved (not started)" : "No key");
    else ST("Update required");
  }

  // expose only the UI hooks
  window.SaveLicenseLocal=SaveK;
  window.CheckLicenseNoSession=CHK;
  window.Launch=LCH;
  window.CleanupOnExit=function(){ try{ END(); }catch(e){} try{ KILL(); }catch(e2){} };
  window.SetDiscordAsStartupUrl=DIS;
  window.InitApp=INIT;
})();
  </script>
</head>

<body onload="InitApp()" onbeforeunload="CleanupOnExit()">
  <div class="wrap">
    <div class="topbar">
      <div class="brandRow">
        <div class="brandLeft">
          <b style="color:#00e5ff;">ScriptNova</b> // Browser Launcher
          <div class="note">Verify/Refresh = no session • Launch = starts session</div>
        </div>
        <div class="brandRight">
          <span id="clientBadge" class="subpill">Client: …</span>
          <span id="licenseStatus" class="pill">No key</span>
        </div>
      </div>
    </div>

    <div class="layout">
      <div class="sidebar">
        <div class="sideTitle">Navigation</div>
        <div class="tab">Launcher</div>

        <div class="sideCard">
          <h4>Support</h4>
          <div class="sideLabel">Email</div>
          <div id="supportEmail" class="sideLine">—</div>

          <div class="sideLabel" style="margin-top:10px;">Discord</div>
          <div id="supportDiscord" class="sideLine">—</div>

          <button id="btnDiscord" class="sideBtn" onclick="SetDiscordAsStartupUrl()">ADD AS STARTUP URL</button>
        </div>
      </div>

      <div class="main">
        <div class="card">
          <h3>License Key</h3>
          <input id="licenseKey" class="field" type="text" placeholder="BASIC-xxxx or PRO-xxxx or FREE-xxxx"/>
          <button id="btnSave" class="btn2" onclick="SaveLicenseLocal()">SAVE LICENSE (LOCAL)</button>
          <button id="btnVerify" class="btn2" onclick="CheckLicenseNoSession()">VERIFY / REFRESH (NO SESSION)</button>
          <p class="note">Thank you for using ScriptNova we dont collect any data besides your key info so we know who is using our unblocker and we do collect error details so we fix them later also we collect your device ID and Device info so we can check if your on our ban list.</p>
        </div>

        <div class="card">
          <h3>Start URL</h3>
          <input id="startUrl" class="field" type="text" value="https://www.guns.lol/iii_dev"/>
        </div>

        <button id="btnLaunch" class="btn" onclick="Launch()">LAUNCH BROWSER ENGINE</button>
      </div>
    </div>
  </div>
</body>
</html>
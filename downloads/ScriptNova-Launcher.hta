<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8"/>
  <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
  <title>ScriptNova — Browser Launcher (HTA)</title>

  <hta:application
    applicationname="ScriptNova"
    id="app"
    border="thin"
    caption="yes"
    maximizebutton="no"
    minimizebutton="yes"
    sysmenu="yes"
    scroll="no"
    singleinstance="yes"
  />

  <style>
    html, body { height:100%; }
    body{ margin:0; font-family:"Segoe UI", Tahoma, Arial; background:#0b0f16; color:#eaf2ff; overflow:hidden; }
    .wrap{ height:100%; padding:14px; box-sizing:border-box; }
    .topbar{ border:1px solid #22314a; border-radius:14px; padding:12px 14px; background:#101828; box-shadow:0 0 18px rgba(0,229,255,0.08); }
    .brandRow{ display:table; width:100%; }
    .brandLeft,.brandRight{ display:table-cell; vertical-align:middle; }
    .brandLeft{ width:70%; }
    .brandRight{ width:30%; text-align:right; color:#9fb2d6; font-size:12px; }
    .pill{ display:inline-block; padding:6px 10px; border-radius:999px; background:#0e2a3a; border:1px solid rgba(0,229,255,0.35); color:#9fefff; font-size:12px; margin-top:6px; }
    .subpill{ display:inline-block; padding:4px 8px; border-radius:999px; background:#0c1422; border:1px solid rgba(255,255,255,0.12); color:#9fb2d6; font-size:11px; margin-top:6px; margin-right:8px; }

    .layout{ margin-top:12px; height:calc(100% - 86px); border:1px solid #22314a; border-radius:14px; background:#0f1726; overflow:hidden; }
    .sidebar{ float:left; width:240px; height:100%; border-right:1px solid #22314a; background:#0c1422; }
    .sideTitle{ padding:12px; border-bottom:1px solid #22314a; color:#9fb2d6; font-size:12px; letter-spacing:.8px; text-transform:uppercase; }

    .tab{ margin:10px; padding:10px; border:1px solid #22314a; border-radius:12px; background:#101a2b; color:#9fb2d6; font-weight:bold; }
    .sideCard{ margin:10px; padding:10px; border:1px solid #22314a; border-radius:12px; background:#0b1220; }
    .sideCard h4{ margin:0 0 8px 0; font-size:12px; letter-spacing:.8px; text-transform:uppercase; color:#9fb2d6; }
    .sideLine{ font-size:12px; color:#cfe1ff; line-height:1.35; word-break:break-word; }
    .sideLabel{ color:#9fb2d6; font-size:11px; margin-top:8px; }
    .sideBtn{
      width:100%;
      padding:10px;
      margin-top:8px;
      border-radius:10px;
      border:1px solid rgba(0,229,255,0.45);
      background:#0e2a3a;
      color:#eaf2ff;
      cursor:pointer;
      font-weight:900;
      letter-spacing:.7px;
      text-transform:uppercase;
      font-size:12px;
    }
    .sideBtn:hover{ background:#103146; }

    .main{ margin-left:240px; height:100%; padding:12px; box-sizing:border-box; overflow-y:auto; }

    .card{ border:1px solid #22314a; border-radius:14px; padding:12px; background:#0b1220; margin-bottom:10px; }
    .card h3{ margin:0 0 8px 0; font-size:12px; letter-spacing:.8px; text-transform:uppercase; color:#9fb2d6; }

    .btn{ width:100%; padding:12px; margin:8px 0; border-radius:12px; border:1px solid rgba(0,229,255,0.45); background:#0e2a3a; color:#eaf2ff; cursor:pointer; font-weight:900; letter-spacing:.7px; text-transform:uppercase; }
    .btn:hover{ background:#103146; }

    .btn2{ width:100%; padding:12px; margin:8px 0; border-radius:12px; border:1px solid rgba(124,77,255,0.45); background:#1a1840; color:#eaf2ff; cursor:pointer; font-weight:900; letter-spacing:.7px; text-transform:uppercase; }
    .btn2:hover{ background:#211f55; }

    .btn:disabled, .btn2:disabled, .sideBtn:disabled{
      opacity:.55; cursor:not-allowed;
      filter:grayscale(35%);
    }

    .field{ width:100%; padding:12px; border-radius:12px; border:1px solid #22314a; background:#070b12; color:#eaf2ff; outline:none; box-sizing:border-box; font-size:16px; }
    .note{ color:#9fb2d6; font-size:11px; line-height:1.35; }
  </style>

  <script language="JScript">
(function(){
  function tr(s){ return String(s||"").replace(/^\s+|\s+$/g,""); }
  function joinParts(a){ return String(a||[]).split(",").join(""); }
  function b64(s){ try{ return window.atob(String(s||"")); }catch(e){ return ""; } }
  function dec(parts){ return b64(joinParts(parts)); }

  function alertOffline(){ alert("API offline"); }
  function alertInvalid(){ alert("Invalid Key"); }
  function alertApi(m){ alert("API error: " + String(m||"unknown")); }
  function alertLimit(){ alert("Too many people using the same key"); }
  function alertLaunch(){ alert("Launcher error"); }
  function alertUpdate(){ alert("Please update to the new file at https://scriptnovaa.com/download"); }

  window.onerror = function(){ try{ alertLaunch(); }catch(e){} return true; };

  var sh = new ActiveXObject("WScript.Shell");
  var fs = new ActiveXObject("Scripting.FileSystemObject");

  var API_BASE = dec(["aHR0","cHM6","Ly9h","cGku","c2Ny","aXB0","bm92","YWEu","Y29t"]);
  var VERSION_URL = dec(["aHR0","cHM6","Ly9h","cGku","c2Ny","aXB0","bm92","YWEu","Y29t","LzEy","MzQv","dmVy","c2lv","bi50","eHQ="]);
  var SUPPORT_EMAIL = dec(["Z29t","ZWdh","YXNz","aXN0","QGdt","YWls","LmNv","bQ=="]);
  var DISCORD_URL = dec(["aHR0","cHM6","Ly9k","aXNj","b3Jk","Lmdn","L2dz","Y0dU","TVZz","V0U="]);

  var Q_CPU  = dec(["U0VM","RUNU","IFBy","b2Nl","c3Nv","cklk","IEZS","T00g","V2lu","MzJf","UHJv","Y2Vz","c29y"]);
  var Q_BIOS = dec(["U0VM","RUNU","IFNl","cmlh","bE51","bWJl","ciBG","Uk9N","IFdp","bjMy","X0JJ","T1M="]);
  var Q_BRD  = dec(["U0VM","RUNU","IFNl","cmlh","bE51","bWJl","ciBG","Uk9N","IFdp","bjMy","X0Jh","c2VC","b2Fy","ZA=="]);
  var REG_GUID = dec(["SEtF","WV9M","T0NB","TF9N","QUNI","SU5F","XFNP","RlRX","QVJF","XE1p","Y3Jv","c29m","dFxD","cnlw","dG9n","cmFw","aHlc","TWFj","aGlu","ZUd1","aWQ="]);

  var END_CHECK  = "/api/check";
  var END_VERIFY = "/api/verify";
  var END_UI     = "/api/ui";
  var END_LAUNCH = "/api/launch";
  var END_PING   = "/api/ping";
  var END_END    = "/api/end";

  var REQUIRED_VERSION = "v13.13.15";

  var state = {
    versionOk:false,
    plan:"none",
    token:"",
    exp:0,
    sid:"",
    pingTimer:null,
    expireTimer:null,
    clientId:"",
    hwid:""
  };

  function setStatus(x){ try{ document.getElementById("licenseStatus").innerText = x; }catch(e){} }
  function setClientBadge(x){
    try{
      var el = document.getElementById("clientBadge");
      if(!el) return;
      x = String(x||"");
      if(x.length>=10) el.innerText = "Client: " + x.substring(0,6) + "…" + x.substring(x.length-4);
      else if(x) el.innerText = "Client: " + x;
      else el.innerText = "Client: none";
    }catch(e){}
  }
  function lockUi(enabled){
    try{document.getElementById("btnSave").disabled=!enabled;}catch(e){}
    try{document.getElementById("btnVerify").disabled=!enabled;}catch(e){}
    try{document.getElementById("btnLaunch").disabled=!enabled;}catch(e){}
    try{document.getElementById("btnDiscord").disabled=!enabled;}catch(e){}
    try{document.getElementById("licenseKey").disabled=!enabled;}catch(e){}
    try{document.getElementById("startUrl").disabled=!enabled;}catch(e){}
  }

  function appDir(){
    var d = sh.ExpandEnvironmentStrings("%APPDATA%") + "\\ScriptNova";
    try{ if(!fs.FolderExists(d)) fs.CreateFolder(d); }catch(e){}
    return d;
  }
  function licensePath(){ return appDir() + "\\license.txt"; }
  function clientPath(){ return appDir() + "\\clientid.txt"; }

  function writeFile(p,txt){
    try{
      var f = fs.CreateTextFile(p,true);
      f.Write(String(txt||""));
      f.Close();
    }catch(e){}
  }
  function readFile(p){
    try{
      if(!fs.FileExists(p)) return "";
      var f = fs.OpenTextFile(p,1,false);
      var s = f.ReadAll();
      f.Close();
      return tr(s);
    }catch(e){ return ""; }
  }

  function validClientId(s){
    s = tr(s);
    if(!s) return false;
    if(s.length<16 || s.length>80) return false;
    return /^[A-Za-z0-9\-_.]+$/.test(s);
  }
  function randHex32(){
    var h="0123456789abcdef", o="", i=0;
    for(i=0;i<32;i++) o+=h.charAt(Math.floor(Math.random()*16));
    return o;
  }
  function ensureClientId(){
    var c = tr(readFile(clientPath()));
    if(validClientId(c)){
      state.clientId = c;
      setClientBadge(c);
      return;
    }
    var g = "";
    try{
      g = String((new ActiveXObject("Scriptlet.TypeLib").Guid)||"");
      g = g.replace("{","").replace("}","").toLowerCase();
    }catch(e){ g=""; }
    if(!validClientId(g)) g = "sn-" + randHex32();
    state.clientId = g;
    writeFile(clientPath(), g);
    setClientBadge(g);
  }

  function wmiOne(query, prop){
    try{
      var svc = GetObject("winmgmts:\\\\.\\root\\cimv2");
      var items = svc.ExecQuery(query);
      var en = new Enumerator(items);
      for(; !en.atEnd(); en.moveNext()){
        var it = en.item(), v="";
        try{ v = it[prop]; }catch(x){ v=""; }
        v = tr(v);
        if(v) return v;
      }
    }catch(e){}
    return "";
  }
  function regRead(path){ try{ return tr(sh.RegRead(path)); }catch(e){ return ""; } }

  function buildHwid(){
    var cpu = wmiOne(Q_CPU, "ProcessorId");
    var bios = wmiOne(Q_BIOS, "SerialNumber");
    var brd = wmiOne(Q_BRD, "SerialNumber");
    var mg = regRead(REG_GUID);
    var cn="", ud="";
    try{ cn = sh.ExpandEnvironmentStrings("%COMPUTERNAME%"); }catch(e){ cn=""; }
    try{ ud = sh.ExpandEnvironmentStrings("%USERDOMAIN%"); }catch(e){ ud=""; }

    var r = tr(cpu)+"|"+tr(bios)+"|"+tr(brd)+"|"+tr(mg)+"|"+tr(cn)+"|"+tr(ud);
    r = r.replace(/\s+/g," ").replace(/\|+/g,"|").replace(/^\|+|\|+$/g,"");
    if(r.length<8 && validClientId(state.clientId)) r = r + "|CID:" + state.clientId;
    if(r.length>220) r = r.substr(0,220);
    return r;
  }

  function httpGet(u){
    var h = new ActiveXObject("MSXML2.ServerXMLHTTP.6.0");
    h.setTimeouts(3000,7000,7000,12000);
    h.open("GET",u,false);
    h.send();
    return { s:h.status, t:h.responseText };
  }
  function httpPost(u,o){
    var h = new ActiveXObject("MSXML2.ServerXMLHTTP.6.0");
    h.setTimeouts(3000,7000,7000,12000);
    h.open("POST",u,false);
    h.setRequestHeader("Content-Type","application/json");
    h.send(JSON.stringify(o));
    return { s:h.status, t:h.responseText };
  }

  function checkVersion(){
    state.versionOk = false;
    lockUi(false);
    var r = httpGet(VERSION_URL);
    if(r.s !== 200){ alertOffline(); alertUpdate(); return false; }
    var rv = tr(r.t||"");
    if(rv !== REQUIRED_VERSION){ alertUpdate(); return false; }
    state.versionOk = true;
    lockUi(true);
    return true;
  }

  function safeUrl(u){
    u = tr(u||"");
    if(!u) return false;
    if(u.indexOf('"')!==-1 || u.indexOf("'")!==-1) return false;
    if(u.indexOf("\r")!==-1 || u.indexOf("\n")!==-1) return false;
    var l = u.toLowerCase();
    return l.indexOf("http://")===0 || l.indexOf("https://")===0;
  }

  function saveLocalKey(){
    if(!state.versionOk){ alertUpdate(); return; }
    var k = tr(document.getElementById("licenseKey").value);
    if(!k){ alertInvalid(); return; }
    writeFile(licensePath(), k);
    setStatus("Key saved (not started)");
  }

  function loadLocalKey(){ return tr(readFile(licensePath())); }

  function checkKeyNoSession(){
    if(!state.versionOk){ alertUpdate(); return; }
    var k = tr(document.getElementById("licenseKey").value);
    if(!k){ alertInvalid(); return; }
    var r = httpGet(API_BASE + END_CHECK + "?license=" + encodeURIComponent(k));
    if(r.s !== 200){ alertOffline(); return; }
    var d = null; try{ d = JSON.parse(r.t); }catch(e){ d = null; }
    if(!d || d.ok !== true){ setStatus("Invalid key"); alertInvalid(); return; }
    setStatus("Key OK (" + d.plan + ") — not started");
  }

  function startSession(){
    if(!state.versionOk) return {ok:false,m:"update_required"};
    if(!validClientId(state.clientId)) ensureClientId();
    state.hwid = buildHwid();

    var k = tr(document.getElementById("licenseKey").value);
    if(!k) return {ok:false,m:"invalid_key"};
    if(!state.hwid || state.hwid.length<8) return {ok:false,m:"bad_hwid"};

    var r = httpPost(API_BASE + END_VERIFY, {
      license:k,
      clientId:String(state.clientId),
      hwid:String(state.hwid)
    });

    if(r.s !== 200){
      var j = null; try{ j = JSON.parse(r.t); }catch(e){ j = null; }
      return {ok:false,m:(j && j.error ? j.error : "offline")};
    }

    var d = null; try{ d = JSON.parse(r.t); }catch(e){ d = null; }
    if(!d || d.ok !== true){
      if(d && d.error) return {ok:false,m:d.error,a:d.active,l:d.limit};
      return {ok:false,m:"invalid"};
    }

    state.plan = d.plan || "basic";
    state.token = String(d.token || "");
    state.exp = parseInt(d.exp,10) || 0;
    state.sid = String(d.sessionId || "");

    if(!state.token || !state.exp || !state.sid) return {ok:false,m:"bad_session"};

    setStatus("Session ACTIVE (" + state.plan + ")");
    armExpiry();
    startHeartbeat();
    return {ok:true};
  }

  function getUiChallenge(){
    var r = httpGet(API_BASE + END_UI + "?token=" + encodeURIComponent(state.token) + "&cid=" + encodeURIComponent(state.clientId));
    if(r.s !== 200){
      var j = null; try{ j = JSON.parse(r.t); }catch(e){ j = null; }
      return {ok:false,e:(j && j.error ? j.error : "ui_failed")};
    }
    var d = null; try{ d = JSON.parse(r.t); }catch(e){ d = null; }
    if(!d || d.ok !== true || !d.launchNonce || !d.launchExp || !d.launchSig || !d.launchProfileId){
      return {ok:false,e:"bad_ui_json"};
    }
    return {ok:true,d:d};
  }

  function getLaunchBundle(u, ui){
    var r = httpPost(API_BASE + END_LAUNCH, {
      token: state.token,
      clientId: state.clientId,
      startUrl: u,
      launchNonce: ui.launchNonce,
      launchExp: ui.launchExp,
      launchSig: ui.launchSig,
      launchProfileId: ui.launchProfileId
    });

    if(r.s !== 200){
      var j = null; try{ j = JSON.parse(r.t); }catch(e){ j = null; }
      return {ok:false,e:(j && j.error ? j.error : "launch_failed")};
    }

    var d = null; try{ d = JSON.parse(r.t); }catch(e){ d = null; }
    if(!d || d.ok !== true || !d.bundle || !d.bundle.flags || !d.bundle.url){
      return {ok:false,e:"bad_launch_json"};
    }
    return {ok:true,b:d.bundle};
  }

  function clearSessionTimers(){
    stopHeartbeat();
    if(state.expireTimer){ try{ window.clearTimeout(state.expireTimer); }catch(e){} state.expireTimer = null; }
  }

  function clearSessionState(){
    state.plan="none"; state.token=""; state.exp=0; state.sid="";
  }

  function handleSessionEnded(reason, doNotify){
    clearSessionTimers();
    try{ killChrome(); }catch(e){}
    clearSessionState();

    reason = tr(reason||"");
    if(reason==="session_expired" || reason==="expired"){
      setStatus("Session EXPIRED");
      if(doNotify) alert("Session expired");
      return;
    }
    if(reason==="session_not_found"){
      setStatus("Session ENDED");
      if(doNotify) alert("Session ended");
      return;
    }
    if(reason==="client_mismatch"){
      setStatus("Session ended (client mismatch)");
      if(doNotify) alert("Session ended: client mismatch");
      return;
    }
    if(reason==="hwid_mismatch"){
      setStatus("Session ended (device mismatch)");
      if(doNotify) alert("Session ended: device mismatch");
      return;
    }
    if(reason){
      setStatus("Session ended (" + reason + ")");
      if(doNotify) alert("Session ended: " + reason);
      return;
    }
    setStatus("Session ended");
    if(doNotify) alert("Session ended");
  }

  function pingOnce(){
    if(!state.token) return;
    try{
      var r = httpPost(API_BASE + END_PING, {token:state.token, clientId:state.clientId});
      var d = null;
      try{ d = JSON.parse(r.t); }catch(e){ d = null; }

      if(r.s === 200 && d && d.ok === true) return;

      handleSessionEnded((d && d.error ? d.error : "ping_failed"), true);
    }catch(e){
      if(state.token) setStatus("Session heartbeat issue");
    }
  }
  function stopHeartbeat(){ if(state.pingTimer){ try{ window.clearInterval(state.pingTimer); }catch(e){} state.pingTimer = null; } }
  function startHeartbeat(){ stopHeartbeat(); pingOnce(); if(state.token) state.pingTimer = window.setInterval(pingOnce, 60000); }
  function endSession(){
    if(!state.token) return;
    clearSessionTimers();
    try{ httpPost(API_BASE + END_END, {token:state.token, clientId:state.clientId}); }catch(e){}
  }

  function armExpiry(){
    if(state.expireTimer){ try{ window.clearTimeout(state.expireTimer); }catch(e){} state.expireTimer = null; }
    if(!state.exp) return;
    var d = (state.exp * 1000) - (new Date().getTime());
    if(d < 0) d = 0;
    state.expireTimer = window.setTimeout(function(){
      endSession();
      handleSessionEnded("session_expired", true);
    }, d);
  }

  function findChrome(){
    var p1 = "C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe";
    var p2 = "C:\\Program Files (x86)\\Google\\Chrome\\Application\\chrome.exe";
    var p3 = sh.ExpandEnvironmentStrings("%LOCALAPPDATA%") + "\\Google\\Chrome\\Application\\chrome.exe";
    if(fs.FileExists(p1)) return p1;
    if(fs.FileExists(p2)) return p2;
    if(fs.FileExists(p3)) return p3;
    return "";
  }

  function killChrome(){
    try{ sh.Run("taskkill /IM chrome.exe /F", 0, true); }catch(e){}
  }

  function normFlag(f){
    f = tr(f||"");
    if(!f) return "";
    if(/[\r\n\t\0]/.test(f)) return "";
    if(f.indexOf("--")!==0) return "";
    if(/[&|<>^`]/.test(f)) return "";
    if(f.indexOf("--user-data-dir=")===0) return "";
    return f;
  }

  function fixUserAgent(f){
    f = String(f||"");
    if(f.indexOf("--user-agent=")!==0) return f;
    var v = tr(f.substring(13)).replace(/"/g,"");
    if(/\s/.test(v)) return '--user-agent="' + v + '"';
    return "--user-agent=" + v;
  }

  function q(s){
    s = String(s||"");
    if(!s) return "";
    if(s.indexOf('"')!==-1) return s;
    if(/\s/.test(s)) return '"' + s + '"';
    return s;
  }

  function buildArgs(flags, url){
    var parts = [];
    var i=0;

    for(i=0;i<flags.length;i++){
      var x = normFlag(flags[i]);
      if(!x) continue;
      x = fixUserAgent(x);
      parts.push(x);
    }

    parts.push("--new-window");
    parts.push(q(url));
    return parts.join(" ");
  }

  function launchShellExecute(exe, args){
    try{
      var sa = new ActiveXObject("Shell.Application");
      sa.ShellExecute(exe, args, "", "open", 1);
      return true;
    }catch(e){
      return false;
    }
  }

  function launchWmi(exe,args){
    try{
      var svc = GetObject("winmgmts:\\\\.\\root\\cimv2");
      var pr = svc.Get("Win32_Process");
      var inp = pr.Methods_("Create").InParameters.SpawnInstance_();
      inp.CommandLine = '"' + exe + '" ' + args;
      var outp = pr.ExecMethod_("Create", inp);
      var rv = 9999;
      try{ rv = outp.ReturnValue; }catch(e){ rv = 9999; }
      return (rv === 0);
    }catch(e){
      return false;
    }
  }

  function launchRun(exe,args){
    var cmd = '"' + exe + '" ' + args;
    try{
      sh.Run(cmd, 1, false);
      return true;
    }catch(e){
      return false;
    }
  }

  function resetSessionUi(){
    clearSessionTimers();
    clearSessionState();
    setStatus("Key saved (not started)");
  }

  function doLaunch(){
    if(!state.versionOk){ alertUpdate(); return; }

    var u = tr(document.getElementById("startUrl").value);
    if(!u) u = "https://example.com";
    if(!safeUrl(u)){ alertApi("unsafe_url"); return; }

    var chrome = findChrome();
    if(!chrome){ alertLaunch(); return; }

    killChrome();

    var s = startSession();
    if(!s.ok){
      if(s.m==="update_required") alertUpdate();
      else if(s.m==="offline") alertOffline();
      else if(s.m==="too_many_sessions") alertLimit();
      else if(s.m==="invalid_key" || s.m==="invalid") alertInvalid();
      else alertApi(s.m);
      resetSessionUi();
      return;
    }

    var ui = getUiChallenge();
    if(!ui.ok){
      if(ui.e==="offline") alertOffline(); else alertApi(ui.e);
      endSession();
      resetSessionUi();
      return;
    }

    var lb = getLaunchBundle(u, ui.d);
    if(!lb.ok){
      if(lb.e==="offline") alertOffline(); else alertApi(lb.e);
      endSession();
      resetSessionUi();
      return;
    }

    var args = buildArgs(lb.b.flags, String(lb.b.url || u));

    if(launchWmi(chrome, args)) return;
    if(launchRun(chrome, args)) return;
    if(launchShellExecute(chrome, args)) return;

    endSession();
    resetSessionUi();
    alertLaunch();
  }

  function setDiscordUrl(){
    if(!state.versionOk){ alertUpdate(); return; }
    try{ document.getElementById("startUrl").value = DISCORD_URL; }catch(e){}
  }

  function init(){
    ensureClientId();
    state.hwid = buildHwid();

    try{ document.getElementById("supportEmail").innerText = SUPPORT_EMAIL; }catch(e){}
    try{ document.getElementById("supportDiscord").innerText = DISCORD_URL; }catch(e){}

    var saved = loadLocalKey();
    if(saved) document.getElementById("licenseKey").value = saved;

    checkVersion();

    if(state.versionOk) setStatus(saved ? "Key saved (not started)" : "No key");
    else setStatus("Update required");
  }

  window.SaveLicenseLocal = saveLocalKey;
  window.CheckLicenseNoSession = checkKeyNoSession;
  window.Launch = doLaunch;
  window.CleanupOnExit = function(){ try{ endSession(); }catch(e){} try{ killChrome(); }catch(e2){} };
  window.SetDiscordAsStartupUrl = setDiscordUrl;
  window.InitApp = init;
})();
  </script>
</head>

<body onload="InitApp()" onbeforeunload="CleanupOnExit()">
  <div class="wrap">
    <div class="topbar">
      <div class="brandRow">
        <div class="brandLeft">
          <b style="color:#00e5ff;">ScriptNova</b> // Browser Launcher
          <div class="note">Verify/Refresh = no session • Launch = starts session</div>
        </div>
        <div class="brandRight">
          <span id="clientBadge" class="subpill">Client: …</span>
          <span id="licenseStatus" class="pill">No key</span>
        </div>
      </div>
    </div>

    <div class="layout">
      <div class="sidebar">
        <div class="sideTitle">Navigation</div>
        <div class="tab">Launcher</div>

        <div class="sideCard">
          <h4>Support</h4>
          <div class="sideLabel">Email</div>
          <div id="supportEmail" class="sideLine">—</div>

          <div class="sideLabel" style="margin-top:10px;">Discord</div>
          <div id="supportDiscord" class="sideLine">—</div>

          <button id="btnDiscord" class="sideBtn" onclick="SetDiscordAsStartupUrl()">ADD AS STARTUP URL</button>
        </div>
      </div>

      <div class="main">
        <div class="card">
          <h3>License Key</h3>
          <input id="licenseKey" class="field" type="text" placeholder="BASIC-xxxx or PRO-xxxx or FREE-xxxx"/>
          <button id="btnSave" class="btn2" onclick="SaveLicenseLocal()">SAVE LICENSE (LOCAL)</button>
          <button id="btnVerify" class="btn2" onclick="CheckLicenseNoSession()">VERIFY / REFRESH (NO SESSION)</button>
          <p class="note">Thank you for using ScriptNova we dont collect any data besides your key info so we know who is using our unblocker and we do collect error details so we fix them later also we collect your device ID and Device info so we can check if your on our ban list.</p>
        </div>

        <div class="card">
          <h3>Start URL</h3>
          <input id="startUrl" class="field" type="text" value="https://www.guns.lol/iii_dev"/>
        </div>

        <button id="btnLaunch" class="btn" onclick="Launch()">LAUNCH BROWSER ENGINE</button>
      </div>
    </div>
  </div>
</body>
</html>